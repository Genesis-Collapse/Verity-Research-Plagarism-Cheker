{
  "name": "originality-engine-root",
  "version": "1.0.0",
  "description": "Root workspace to run both frontend and backend concurrently",
  "private": true,
  "scripts": {
    "install:all": "cd frontend && npm install",
    "dev:backend": "cd backend && .\\venv\\Scripts\\python.exe -m uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently -c \"blue,green\" -n \"BACKEND,FRONTEND\" \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "firebase": "^12.13.0"
  }
}
